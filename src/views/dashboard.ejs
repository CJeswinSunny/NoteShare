<%- include('partials/head', { pageTitle: 'Dashboard', metaDesc: 'Browse and search student notes on NoteShare.' }) %>
<%- include('partials/navbar') %>

<main class="app-main">
  <div class="container">
    <!-- Page Header -->
    <div class="page-header">
      <div>
        <h1 class="page-title">Browse Notes</h1>
        <p class="page-sub">Discover notes shared by the community</p>
      </div>
      <a href="/upload" class="btn btn-primary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M12 5v14M5 12l7-7 7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Upload Note
      </a>
    </div>

    <!-- Stats Bar -->
    <div class="stats-bar">
      <div class="stat-pill">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <strong><%= stats.totalNotes %></strong> Total Notes
      </div>
      <div class="stat-pill">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <strong><%= stats.myUploads %></strong> My Uploads
      </div>
      <div class="stat-pill">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <strong><%= stats.totalDownloads %></strong> My Downloads Generated
      </div>
    </div>

    <!-- Search & Filter -->
    <div class="search-bar-wrap">
      <form action="/dashboard" method="GET" class="search-form" id="searchForm">
        <div class="search-input-wrap">
          <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="2"/><path d="m21 21-4.35-4.35" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
          <input type="text" name="search" id="searchInput" placeholder="Search notes by title or description…" value="<%= search %>" class="search-input" autocomplete="off">
          <% if (search) { %><button type="button" class="search-clear" onclick="clearSearch()">✕</button><% } %>
        </div>
        <select name="subject" id="subjectFilter" class="subject-select" onchange="this.form.submit()">
          <option value="">All Subjects</option>
          <% subjects.forEach(s => { %>
            <option value="<%= s %>" <%= subject === s ? 'selected' : '' %>><%= s %></option>
          <% }) %>
        </select>
        <button type="submit" class="btn btn-primary">Search</button>
        <% if (search || subject) { %>
          <a href="/dashboard" class="btn btn-ghost">Clear</a>
        <% } %>
      </form>
    </div>

    <!-- Active filters indicator -->
    <% if (search || subject) { %>
    <div class="filter-tags">
      <span class="filter-label">Filtered by:</span>
      <% if (search) { %><span class="filter-tag">"<%= search %>"</span><% } %>
      <% if (subject) { %><span class="filter-tag subject-tag"><%= subject %></span><% } %>
      <span class="filter-count"><%= notes.length %> result<%= notes.length !== 1 ? 's' : '' %></span>
    </div>
    <% } %>

    <!-- Notes Grid -->
    <% if (notes.length === 0) { %>
      <div class="empty-state">
        <div class="empty-icon">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none"><path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <h3><%= (search || subject) ? 'No notes found' : 'No notes yet' %></h3>
        <p><%= (search || subject) ? 'Try adjusting your search or filters.' : 'Be the first to share a note!' %></p>
        <a href="/upload" class="btn btn-primary">Upload First Note</a>
      </div>
    <% } else { %>
      <div class="notes-grid" id="notesGrid">
        <% notes.forEach(note => { %>
          <%- include('partials/note-card', { note }) %>
        <% }) %>
      </div>
    <% } %>
  </div>
</main>

<%- include('partials/footer') %>
